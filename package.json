{
  "name": "magic-mirror",
  "version": "1.3.2",
  "description": "GitHub App that syncs upstream repositories with forks using PRs",
  "license": "GPL-3.0-or-later",
  "author": "Red Hat",
  "scripts": {
    "build": "npx tsc",
    "dev": "npm run build && touch magic-mirror.db && concurrently npm:syncer npm:web -n syncer,web -c green,blue",
    "lint": "eslint src --ext .ts",
    "syncer": "node ./build/scripts/start-syncer.js",
    "test": "jest --runInBand ./src",
    "web": "node ./build/scripts/start-web.js"
  },
  "jest": {
    "collectCoverage": true,
    "coverageThreshold": {
      "global": {
        "lines": 90
      }
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(@octokit|@probot|before-after-hook|find-up-simple|import-meta-resolve|load-json-file|npx-import-light|octokit-auth-probot|package-config|probot|universal-github-app-jwt|universal-user-agent)/)"
    ],
    "moduleNameMapper": {
      "^@octokit/auth-unauthenticated$": "<rootDir>/node_modules/@octokit/auth-unauthenticated/dist-src/index.js",
      "^@octokit/plugin-enterprise-compatibility$": "<rootDir>/node_modules/@octokit/plugin-enterprise-compatibility/dist-src/index.js",
      "^@octokit/webhooks-methods$": "<rootDir>/node_modules/@octokit/webhooks-methods/dist-node/index.js",
      "^@probot/octokit-plugin-config$": "<rootDir>/node_modules/@probot/octokit-plugin-config/dist-src/index.js"
    }
  },
  "dependencies": {
    "@octokit/auth-app": "^8.2.0",
    "@octokit/openapi-types": "^27.0.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-types": "^7.6.1",
    "js-yaml": "^4.1.0",
    "probot": "^14.3.2",
    "simple-git": "^3.36.0",
    "sqlite3": "^6.0.1",
    "tmp": "^0.2.5",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@octokit/webhooks-methods": "^6.0.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/supertest": "^7.2.0",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-google": "^0.14.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "nock": "^14.0.12",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=24"
  }
}
